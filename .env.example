# Azure DevOps PAT (server-only). Scopes: Work Items (Read), Project and Team (Read)
AZURE_DEVOPS_PAT=your_pat_here

# Optional override (default: tr-ggo)
AZURE_DEVOPS_ORG=tr-ggo

# Prisma SQLite (default path for local dev)
DATABASE_URL="file:./dev.db"

# Optional: org slug for links in the browser (default tr-ggo)
NEXT_PUBLIC_AZURE_DEVOPS_ORG=tr-ggo

# Legacy (ignored by current export): path to a .pptx used only as design reference in docs/templates
# DELIVERY_PPT_TEMPLATE_PATH=C:\Users\you\Downloads\TEMPLEATE.pptx
